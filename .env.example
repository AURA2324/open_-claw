# WhatsApp Business API
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

# Internal Order System
ORDER_SYSTEM_API_URL=https://your-order-system-api.com
ORDER_SYSTEM_API_KEY=your_api_key
ORDER_SYSTEM_DB_HOST=localhost
ORDER_SYSTEM_DB_USER=user
ORDER_SYSTEM_DB_PASSWORD=password
ORDER_SYSTEM_DB_NAME=orders

# Server Configuration
PORT=3000
NODE_ENV=development

# Tanzania Phone Number Prefix
TANZANIA_PREFIX=+255

# Token Optimization
CACHE_TTL=3600
MAX_CACHE_SIZE=1000
